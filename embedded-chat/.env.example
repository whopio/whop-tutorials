# Copy to .env.local and fill in. Create the API key + find your company ID
# at sandbox.whop.com/dashboard (Developer -> API Keys). The key authenticates
# only against the sandbox host.
WHOP_COMPANY_API_KEY=apik_your_sandbox_key
WHOP_COMPANY_ID=biz_your_company_id
WHOP_SANDBOX=true
APP_URL=http://localhost:3000

# ── Production (optional): powers the "Prebuilt embed" tab with the real ──
# <ChatElement> on a separate production company. Leave unset to run on sandbox
# only; the embed tab then shows a placeholder. Set both, then run
# `npm run setup:prod` to provision and generate constants/whop-ids.prod.ts.
WHOP_PROD_API_KEY=apik_your_production_key
WHOP_PROD_COMPANY_ID=biz_your_production_company_id
# A real, deliverable throwaway inbox the demo accounts are created from.
# Used only by setup:prod, never at runtime. Production rejects fake addresses.
WHOP_PROD_DEMO_EMAIL=your-demo-inbox@example.com

# ── Generated by `npm run setup` (scripts/setup-sandbox.mjs) ──────────────
# Demo users, product, chat experience, channels, DM and support chat IDs
# are written here automatically. Do not fill these in by hand.
