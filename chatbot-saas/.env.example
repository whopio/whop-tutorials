# ============================================
# WHOP SANDBOX (Development)
# ============================================
# Create a sandbox account at https://sandbox.whop.com
# Get your keys from sandbox.whop.com > Developer > Your App
#
# In sandbox, use these test cards:
#   4242 4242 4242 4242  — successful payment
#   4000 0000 0000 0002  — declined payment
# Any future expiry date and any 3-digit CVC will work.
# ============================================

# Whop OAuth & App (from sandbox.whop.com in dev, whop.com in prod)
WHOP_APP_ID=app_...
WHOP_API_KEY=apik_...
WHOP_COMPANY_ID=biz_...
WHOP_CLIENT_ID=
WHOP_CLIENT_SECRET=

# Whop Company API Key (separate from app key — needed for product/plan creation)
# Get from: Business Settings > API Keys
WHOP_COMPANY_API_KEY=apik_...

# Whop Webhook Secret (from sandbox.whop.com > Developer > Webhooks)
# Events: membership_activated, membership_deactivated
WHOP_WEBHOOK_SECRET=ws_...

# Sandbox mode — set to "true" for development, remove entirely for production
# Controls Whop SDK base URL (sandbox-api.whop.com vs api.whop.com)
WHOP_SANDBOX=true

# Database (Neon via Vercel integration)
# DATABASE_URL uses PgBouncer pooling (runtime)
# DATABASE_URL_UNPOOLED is direct connection (Prisma CLI only)
DATABASE_URL=postgresql://...
DATABASE_URL_UNPOOLED=postgresql://...

# Session encryption (generate with: openssl rand -base64 32)
SESSION_SECRET=generate-a-random-string-at-least-32-characters

# App URL
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI Providers
# Anthropic: https://console.anthropic.com
# OpenAI: https://platform.openai.com
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
