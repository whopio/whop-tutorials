# Database (Neon)
# DATABASE_URL = pooled connection (host contains "-pooler"), used by the app for queries
# DIRECT_URL   = direct/unpooled connection (host without "-pooler"), used by the Prisma CLI
DATABASE_URL="postgresql://[user]:[password]@ep-xxxx-pooler.[region].aws.neon.tech/[db]?sslmode=require"
DIRECT_URL="postgresql://[user]:[password]@ep-xxxx.[region].aws.neon.tech/[db]?sslmode=require"

# Whop
WHOP_API_KEY=apik_your_company_api_key
WHOP_APP_ID=app_your_app_id
WHOP_COMPANY_ID=biz_your_company_id
WHOP_CLIENT_ID=app_your_app_id
WHOP_CLIENT_SECRET=apik_your_app_api_key
WHOP_WEBHOOK_SECRET=your_webhook_secret
WHOP_SANDBOX=true

# Uploadthing
UPLOADTHING_TOKEN=your_uploadthing_token

# Session (min 32 characters)
SESSION_SECRET=your-session-secret-at-least-32-characters-long

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Seed (optional — real email for creating Whop sandbox companies during seeding)
# SEED_EMAIL=your-email@example.com
