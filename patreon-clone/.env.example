# Database (Neon / Vercel Postgres)
POSTGRES_PRISMA_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLED="postgresql://user:password@host/db?sslmode=require"

# Session encryption — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="your-32-character-minimum-secret"

# Public app URL (no trailing slash)
AUTH_URL="http://localhost:3000"

# Use the Whop sandbox during development ("true" / "false")
WHOP_SANDBOX="true"

# Whop OAuth + API (Developer page of your Whop dashboard)
WHOP_APP_ID="app_xxxxxxxxxxxxx"
WHOP_CLIENT_SECRET="your-app-oauth-client-secret"
WHOP_API_KEY="apik_xxxxxxxxxxxxx"
WHOP_COMPANY_ID="biz_xxxxxxxxxxxxx"
WHOP_WEBHOOK_SECRET="ws_xxxxxxxxxxxxx"
