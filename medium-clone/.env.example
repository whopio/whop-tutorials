# ─── Auth (Part 1) ────────────────────────────
WHOP_APP_API_KEY=apik_xxxxxxxxxxxxxxxxxxxxxxxx
WHOP_CLIENT_ID=app_xxxxxxxxxxxxxx
WHOP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SESSION_SECRET=use-openssl-rand-base64-32-or-longer
NEXT_PUBLIC_APP_URL=https://storyline-six.vercel.app

# ─── Database (Part 1, via Vercel + Neon) ─────
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.neon.tech/storyline?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.neon.tech/storyline?sslmode=require

# ─── Whop for Platforms (Part 3 onward) ───────
WHOP_COMPANY_API_KEY=apik_yyyyyyyyyyyyyyyyyyyy
WHOP_COMPANY_ID=biz_xxxxxxxxxxxx
WHOP_WEBHOOK_SECRET=ws_xxxxxxxxxxxxxxxxxxxxxxxx
STORYLINE_PLUS_PLAN_ID=plan_xxxxxxxxxxxx

# ─── UploadThing (Part 2) ─────────────────────
UPLOADTHING_TOKEN=ut_xxxxxxxxxxxxxxxx

# ─── Operator (Part 5) ────────────────────────
# Root operator. Lowercased on use; upserted as an Operator row on every admin
# access so /admin/* is gated to this email. Set to your own Whop login email.
ROOT_OPERATOR_EMAIL=your-email@example.com
OPERATOR_TOPUP_PAYMENT_METHOD_ID=

# ─── Cron (Part 6) ────────────────────────────
CRON_SECRET=use-openssl-rand-base64-32

# ─── Config ───────────────────────────────────
WHOP_SANDBOX=true
NEXT_PUBLIC_WHOP_SANDBOX=true
TIP_PLATFORM_FEE_PERCENT=10
PLATFORM_PLUS_FEE_PERCENT=30
STORYLINE_PLUS_MONTHLY_PRICE=5
PARTNER_PAYOUT_MIN_USD=1
