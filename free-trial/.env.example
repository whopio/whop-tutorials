# Whop Company API key (Dashboard > Developer > Company API keys, on sandbox).
# Needs: payment:basic:read, plan:basic:read, access_pass:basic:read,
# member:basic:read, member:manage, membership:cancel, member:email:read.
# Add access_pass:create if you provision the products from the scripts.
WHOP_COMPANY_API_KEY=apik_...

# Your company id (biz_..., in your dashboard URL). Only used by scripts/.
WHOP_COMPANY_ID=biz_...

# The product the trial unlocks and its recurring plan with the trial days.
WHOP_PRO_PRODUCT_ID=prod_...
WHOP_PRO_PLAN_ID=plan_...

# true = sandbox-api.whop.com + sandbox checkout embed. Remove in production.
WHOP_SANDBOX=true

# iron-session seal password. Generate: openssl rand -base64 32
SESSION_SECRET=

# The app origin. Must exactly match a redirect URI registered on the Whop app.
APP_URL=http://localhost:3000

# Demo-only: Whop app OAuth credentials for the "Sign in with Whop" restore path.
# App needs the oauth:token_exchange permission and openid+profile scopes.
WHOP_CLIENT_ID=app_...
WHOP_CLIENT_SECRET=...
