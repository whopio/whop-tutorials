# Whop Company API key (Business settings > API keys, sandbox toggled on).
# Needs: payment:basic:read, plan:basic:read, access_pass:basic:read, member:basic:read
WHOP_COMPANY_API_KEY=apik_...

# Your Whop company id (biz_...). Only used by scripts/setup-sandbox.mjs.
WHOP_COMPANY_ID=biz_...

# The product that unlocks every premium post (its plan is recurring).
WHOP_PRO_PRODUCT_ID=prod_...
WHOP_PRO_PLAN_ID=plan_...

# true = sandbox-api.whop.com + sandbox checkout embed. Remove in production.
WHOP_SANDBOX=true

# iron-session seal password, at least 32 characters. Generate: openssl rand -base64 32
SESSION_SECRET=

# The app origin. Must exactly match a redirect URI registered on the Whop app.
APP_URL=http://localhost:3000

# Demo-only: Whop app OAuth credentials for the "Sign in with Whop" restore path.
# App needs the oauth:token_exchange permission and openid+profile scopes.
WHOP_CLIENT_ID=app_...
WHOP_CLIENT_SECRET=...
