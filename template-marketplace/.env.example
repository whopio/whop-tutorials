# Database (Neon via Vercel Marketplace integration)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Whop OAuth (from app OAuth tab)
WHOP_CLIENT_ID=
WHOP_CLIENT_SECRET=

# Whop App API Key (Developer > Apps > your app > API Keys) - used for OAuth + webhooks
WHOP_API_KEY=

# Whop Company API Key (Business Settings > API Keys) - used for products, plans,
# checkout configurations, and promo codes (has the access_pass:create scope)
WHOP_COMPANY_API_KEY=

# Platform parent company ID (starts with biz_) - every seller's sub-company
# is created under this one
WHOP_COMPANY_ID=

# Whop Webhook secret (Developer > Webhooks, company-level webhook on the parent
# company with "Connected account events" enabled)
WHOP_WEBHOOK_SECRET=

# Session (generate with: openssl rand -base64 32)
SESSION_SECRET=

# App URL (your Vercel URL in production, http://localhost:3000 in dev)
NEXT_PUBLIC_APP_URL=

# UploadThing (from uploadthing.com project settings)
UPLOADTHING_TOKEN=

# Development only - forces SDK + OAuth to sandbox-api.whop.com (remove in production)
WHOP_SANDBOX=true

# Platform fee percentage (default: 5)
PLATFORM_FEE_PERCENT=5
