# Public web origin. Use your Vercel/custom domain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Allow Chrome extension origins to call /api/extension/*.
# During local unpacked-extension development you can use "*".
# In production prefer: chrome-extension://YOUR_PUBLISHED_EXTENSION_ID
EXTENSION_ALLOWED_ORIGINS=*

# Whop OAuth app id. This is safe to expose to the extension.
NEXT_PUBLIC_WHOP_APP_ID=app_xxxxxxxxxxxxx

# Whop resource to check access against. Use exp_ for a Whop experience, prod_ for a product, or biz_ for a company.
WHOP_ACCESS_RESOURCE_ID=exp_or_prod_xxxxxxxxxxxxx

# Optional Whop company/business id. Used for server-side membership billing portal lookup.
WHOP_COMPANY_ID=biz_xxxxxxxxxxxxx

# Whop checkout plan id for the paid tier.
WHOP_PLAN_ID=plan_xxxxxxxxxxxxx

# Whop-hosted customer membership billing page.
WHOP_BILLING_PORTAL_FALLBACK_URL=https://whop.com/@me/settings/memberships/

# Server-only Whop API key. Never put this in the extension.
WHOP_API_KEY=

# Optional webhook secret from the Whop dashboard.
WHOP_WEBHOOK_SECRET=

# Keep true until real Whop app, redirect URI, resource id, and API key are ready.
WHOP_MOCK_MODE=true

# If true, users without Whop access still receive the free feature set.
WHOP_ALLOW_FREE_ACCESS=true
