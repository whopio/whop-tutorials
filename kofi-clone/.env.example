# ---- Database ----
# Local dev: a Postgres connection string. Production: Neon via Vercel (POSTGRES_PRISMA_URL).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kofi_clone?schema=public"

# ---- Session ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="a-random-string-at-least-32-characters-long"

# ---- App ----
# Dev runs on port 3005 to match the OAuth redirect registered in Whop.
NEXT_PUBLIC_APP_URL="http://localhost:3005"

# ---- Whop ----
# Use sandbox while developing. Switch to "false" + production keys to go live.
WHOP_SANDBOX="true"

# Your platform company id (parent for all connected creator accounts). Dashboard > Settings.
WHOP_PLATFORM_COMPANY_ID="biz_xxxxxxxxxxxxx"
NEXT_PUBLIC_WHOP_COMPANY_ID="biz_xxxxxxxxxxxxx"

# OAuth app credentials. Developer > Apps. Add redirect URI: <APP_URL>/oauth/callback
WHOP_CLIENT_ID="app_xxxxxxxxxxxxx"
NEXT_PUBLIC_WHOP_APP_ID="app_xxxxxxxxxxxxx"
WHOP_CLIENT_SECRET="your-app-oauth-client-secret"

# Company API key. Business Settings > API Keys.
WHOP_COMPANY_API_KEY="apik_xxxxxxxxxxxxx"

# Webhook signing secret. Developer > Webhooks.
WHOP_WEBHOOK_SECRET=""

# Platform application fee percentage (0-100).
NEXT_PUBLIC_PLATFORM_FEE_PERCENT="5"
