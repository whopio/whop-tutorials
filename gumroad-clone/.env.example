# Database (Neon via Vercel integration)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Whop OAuth (from app OAuth tab)
WHOP_CLIENT_ID=
WHOP_CLIENT_SECRET=

# Whop API Keys
WHOP_API_KEY=
WHOP_COMPANY_ID=
WHOP_COMPANY_API_KEY=

# Whop Webhook (from Developer > Webhooks)
WHOP_WEBHOOK_SECRET=

# Session (generate with: openssl rand -base64 32)
SESSION_SECRET=

# App URL (your Vercel URL, e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=

# UploadThing (from uploadthing.com project settings)
UPLOADTHING_TOKEN=

# Development only (remove for production)
WHOP_SANDBOX=true

# Platform fee percentage (default: 5)
PLATFORM_FEE_PERCENT=5
