# ----------------------------------------------------------------------------
# Whop
# Developer Dashboard: https://sandbox.whop.com/developer
# ----------------------------------------------------------------------------

# OAuth client ID (App settings > OAuth)
WHOP_CLIENT_ID=

# OAuth client secret (same page as client ID)
WHOP_CLIENT_SECRET=

# API key for server-side SDK calls and webhook verification (App settings > API Keys)
WHOP_API_KEY=

# Company / business ID (used by prisma/create-pro-plan.ts to create the Pro product)
WHOP_COMPANY_ID=

# Set to "true" for sandbox. Remove or set to "false" for production.
WHOP_SANDBOX=true

# Webhook signing secret (Developer > Webhooks > Your endpoint)
WHOP_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Database (Neon recommended, provisioned via Vercel Marketplace)
# ----------------------------------------------------------------------------

# Pooled connection string — used at runtime by the Next.js app
DATABASE_URL=

# Direct (non-pooled) connection string — used by the Prisma CLI
DATABASE_URL_UNPOOLED=

# ----------------------------------------------------------------------------
# Session
# ----------------------------------------------------------------------------

# 32+ byte secret for iron-session cookie encryption.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------

# Public URL of the app. Used to construct OAuth redirect URIs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# AI providers (direct keys, not Vercel AI Gateway)
# ----------------------------------------------------------------------------

# Anthropic API key for Claude models (used by @ai-sdk/anthropic)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API key for GPT models (used by @ai-sdk/openai)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
