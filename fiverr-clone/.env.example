# Copy this file to .env.local and fill in your values.
# Do not commit .env.local — it is git-ignored.

# === Supabase ===
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Whop platform ===
# Developer → API Keys in your Whop dashboard
WHOP_API_KEY=
# Your platform parent company ID (biz_xxxxxxxxxxxx) from the dashboard URL
WHOP_PLATFORM_COMPANY_ID=biz_XXXXXXXXXXXX
# Developer → Webhooks → your endpoint signing secret
WHOP_WEBHOOK_SECRET=
# Take rate in basis points. 1000 = 10%, 500 = 5%.
PLATFORM_FEE_BPS=1000

# Optional. Set when your Company API key lacks dms:channel:manage and you
# need an App API key for DM/chat. The chat routes prefer this when set.
# WHOP_APP_API_KEY=

# === Whop OAuth (Login with Whop + chat scopes) ===
# Developer → Apps → OAuth in your Whop dashboard
WHOP_OAUTH_CLIENT_ID=
WHOP_OAUTH_CLIENT_SECRET=
# Must exactly match the redirect URI registered in your Whop OAuth app
NEXT_PUBLIC_WHOP_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/whop

# === App ===
# Canonical base URL of your deployment. Set this in production so redirects
# never hit a Vercel preview URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# sandbox uses sandbox-api.whop.com; production uses api.whop.com
NEXT_PUBLIC_WHOP_ENVIRONMENT=sandbox
